.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Firebase – this is necessary if you use Firebase since it could otherwise 
# lead to leaking of private certificates to your repository, which is no bueno.
.firebase/

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Supabase CLI temp
supabase/.temp/

# Local previews / duplicates at repo root
/bazar_preview.html
/zag.jpg

# Dev tool dependencies
tools/bg-remove/node_modules/
tools/bg-remove/backup/

# Distribution archives
*.zip
*.apk

# JVM crash dumps
hs_err_pid*.log

# Admin app local build output (source may live in admin_app/)
admin_app/build/
admin_app/.dart_tool/
admin_app/.flutter-plugins
admin_app/.flutter-plugins-dependencies

# Design HTML previews (not shipped)
design/**/*.html

